# Optional Mac bridge configuration.
#
# Leave this file as an example in Git. For local use, copy it to:
#   mac/bridge.env
# or edit:
#   ~/Library/Application Support/ParsecBubbleInput/bridge.env

# Listen on all interfaces so the Android phone can reach the Mac on the LAN.
PBI_HOST=0.0.0.0
PBI_PORT=8765

# Optional. If omitted, the bridge generates a private token in:
#   ~/Library/Application Support/ParsecBubbleInput/.token
# PBI_TOKEN=change-me-to-a-long-random-string

# Optional relay URL for off-LAN use. Keep empty for direct LAN/Tailscale use.
# PBI_RELAY_URL=https://your-relay.example.com
